IAArB,SAAQ,EAAE,QAAA,CAAA;EAAO,CAAA,EAAA,IAAA,EAAA,CAAA,EAAA,CAAA,WAAA,CAAA,CAAA,EAC7B,YAAA,CAAiC,wBAAA,EAAA;IAAjB,EAAE,EAAE,KAAA,CAAA,EAAE,CAAC;uBACvB,YAAA,CAAqD,mBAAA,EAAA;IAA1C,SAAS,EAAE,KAAA,CAAA,EAAE;IAAG,YAAU,EAAE,QAAA,CAAA","sourcesContent":["<template>\n  <div id=\"app\">\n    <div v-if=\"!isAuthenticated\" class=\"auth-card\">\n      <h1>Авторизация</h1>\n\n      <div class=\"auth-switch\">\n        <button\n          :class=\"{ active: authMode === 'signin' }\"\n          type=\"button\"\n          @click=\"setAuthMode('signin')\"\n        >\n          Вход\n        </button>\n        <button\n          :class=\"{ active: authMode === 'signup' }\"\n          type=\"button\"\n          @click=\"setAuthMode('signup')\"\n        >\n          Регистрация\n        </button>\n      </div>\n\n      <form class=\"auth-form\" @submit.prevent=\"submitAuth\">\n        <label>\n          Логин\n          <input v-model.trim=\"authForm.username\" required minlength=\"3\" />\n        </label>\n\n        <label v-if=\"authMode === 'signup'\">\n          Email\n          <input v-model.trim=\"authForm.email\" type=\"email\" required />\n        </label>\n\n        <label>\n          Пароль\n          <input\n            v-model=\"authForm.password\"\n            type=\"password\"\n            required\n            minlength=\"6\"\n          />\n        </label>\n\n        <button class=\"primary-btn\" type=\"submit\" :disabled=\"isAuthLoading\">\n          {{ isAuthLoading ? 'Подождите...' : authMode === 'signin' ? 'Войти' : 'Создать аккаунт' }}\n        </button>\n      </form>\n\n      <p v-if=\"authError\" class=\"auth-error\">{{ authError }}</p>\n      <p v-if=\"authSuccess\" class=\"auth-success\">{{ authSuccess }}</p>\n    </div>\n\n    <template v-else>\n      <div class=\"toolbar\">\n        <span class=\"welcome\">Пользователь: {{ currentUsername || 'unknown' }}</span>\n        <button type=\"button\" class=\"logout-btn\" @click=\"logout\">Выйти</button>\n      </div>\n\n      <InputItem @add-item=\"addItem\" />\n      <TodoInProcess :db=\"db.length\" />\n      <TodoList :todoLists=\"db\" @removeItem=\"removeTodo\" />\n    </template>\n  </div>\n</template>\n\n<script>\n//@ - указывает путь от папки src\nimport InputItem from '@/components/InputItem.vue';\nimport TodoInProcess from '@/components/TodoInProcess.vue';\nimport TodoList from '@/components/TodoList.vue';\nimport api from '@/services/api';\n\nconst TODOS_ENDPOINT = process.env.VUE_APP_TODOS_ENDPOINT || '/todos';\nconst SIGNIN_ENDPOINT = process.env.VUE_APP_AUTH_SIGNIN_ENDPOINT || '/auth/signin';\nconst SIGNUP_ENDPOINT = process.env.VUE_APP_AUTH_SIGNUP_ENDPOINT || '/auth/signup';\nconst AUTH_VERIFY_ENDPOINT = process.env.VUE_APP_AUTH_VERIFY_ENDPOINT || '/user';\nconst AUTH_TOKEN_KEY = process.env.VUE_APP_AUTH_TOKEN_KEY || 'accessToken';\nconst AUTH_USER_KEY = process.env.VUE_APP_AUTH_USER_KEY || 'authUsername';\n\nexport default {\n  name: 'App',\n  data() {\n    return {\n      db: [],\n      isAuthenticated: false,\n      isAuthLoading: false,\n      authMode: 'signin',\n      currentUsername: '',\n      authError: '',\n      authSuccess: '',\n      authForm: {\n        username: '',\n        email: '',\n        password: '',\n      },\n    };\n  },\n  async mounted() {\n    await this.restoreSession();\n  },\n  //Регистрируем компоненты\n  components: {\n    InputItem,\n    TodoInProcess,\n    TodoList,\n  },\n  methods: {\n    setAuthMode(mode) {\n      this.authMode = mode;\n      this.authError = '';\n      this.authSuccess = '';\n    },\n    async restoreSession() {\n      const token = localStorage.getItem(AUTH_TOKEN_KEY);\n      const savedUsername = localStorage.getItem(AUTH_USER_KEY);\n\n      if (!token) {\n        return;\n      }\n\n      this.currentUsername = savedUsername || '';\n\n      try {\n        await api.get(AUTH_VERIFY_ENDPOINT);\n        this.isAuthenticated = true;\n        await this.fetchTodos();\n      } catch (error) {\n        this.logout();\n      }\n    },\n    async submitAuth() {\n      if (this.isAuthLoading) {\n        return;\n      }\n\n      this.authError = '';\n      this.authSuccess = '';\n      this.isAuthLoading = true;\n\n      try {\n        if (this.authMode === 'signup') {\n          await api.post(SIGNUP_ENDPOINT, {\n            username: this.authForm.username,\n            email: this.authForm.email,\n            password: this.authForm.password,\n          });\n          this.authSuccess = 'Регистрация успешна.';\n        }\n\n        await this.signInWithCredentials(\n          this.authForm.username,\n          this.authForm.password,\n        );\n      } catch (error) {\n        this.authError = error?.response?.data?.message || 'Ошибка авторизации.';\n      } finally {\n        this.isAuthLoading = false;\n      }\n    },\n    async signInWithCredentials(username, password) {\n      const response = await api.post(SIGNIN_ENDPOINT, { username, password });\n      const token = response?.data?.accessToken;\n\n      if (!token) {\n        throw new Error('Token was not returned');\n      }\n\n      const userName = response?.data?.username || username;\n\n      localStorage.setItem(AUTH_TOKEN_KEY, token);\n      localStorage.setItem(AUTH_USER_KEY, userName);\n\n      this.currentUsername = userName;\n      this.isAuthenticated = true;\n      this.authForm.password = '';\n\n      await this.fetchTodos();\n    },\n    async fetchTodos() {\n      const response = await api.get(TODOS_ENDPOINT);\n      this.db = response.data;\n    },\n    logout() {\n      localStorage.removeItem(AUTH_TOKEN_KEY);\n      localStorage.removeItem(AUTH_USER_KEY);\n\n      this.isAuthenticated = false;\n      this.currentUsername = '';\n      this.authForm.password = '';\n      this.db = [];\n    },\n    //Удаляем задачу по id\n    async removeTodo(id) {\n      if (!this.isAuthenticated) {\n        return;\n      }\n      await api.delete(`${TODOS_ENDPOINT}/${id}`);\n      await this.fetchTodos();\n    },\n    //Добавляем новую задачу\n    async addItem(item) {\n      if (!this.isAuthenticated) {\n        return;\n      }\n      await api.post(TODOS_ENDPOINT, item);\n      await this.fetchTodos();\n    },\n  },\n};\n</script>\n\n<style>\n#app {\n  font-family: Avenir, Helvetica, Arial, sans-serif;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n  color: #2c3e50;\n  width: 80%;\n  margin: 0 auto;\n  margin-top: 60px;\n}\n\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nul {\n  list-style: none;\n}\n\nh1 {\n  margin-bottom: 16px;\n}\n\n.auth-card {\n  width: 100%;\n  max-width: 460px;\n  margin: 80px auto 0;\n  border: 1px solid #d4d9e5;\n  border-radius: 12px;\n  padding: 24px;\n  text-align: left;\n  background: #fff;\n}\n\n.auth-switch {\n  display: flex;\n  gap: 8px;\n  margin-bottom: 16px;\n}\n\n.auth-switch button {\n  flex: 1;\n  border: 1px solid #2947cc;\n  background: #fff;\n  color: #2947cc;\n  border-radius: 8px;\n  padding: 8px 10px;\n  cursor: pointer;\n}\n\n.auth-switch button.active {\n  background: #2947cc;\n  color: #fff;\n}\n\n.auth-form {\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n}\n\n.auth-form label {\n  font-size: 14px;\n  display: flex;\n  flex-direction: column;\n  gap: 6px;\n}\n\n.auth-form input {\n  height: 36px;\n  border: 1px solid #c3cbe0;\n  border-radius: 8px;\n  padding: 0 10px;\n}\n\n.primary-btn {\n  height: 38px;\n  border-radius: 8px;\n  border: 1px solid #2947cc;\n  background: #2947cc;\n  color: #fff;\n  cursor: pointer;\n}\n\n.primary-btn:disabled {\n  opacity: 0.6;\n  cursor: not-allowed;\n}\n\n.auth-error {\n  margin-top: 12px;\n  color: #d32f2f;\n}\n\n.auth-success {\n  margin-top: 12px;\n  color: #2e7d32;\n}\n\n.toolbar {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 16px;\n}\n\n.welcome {\n  font-weight: 700;\n}\n\n.logout-btn {\n  border: 1px solid #d32f2f;\n  background: #fff;\n  color: #d32f2f;\n  border-radius: 8px;\n  height: 34px;\n  padding: 0 12px;\n  cursor: pointer;\n}\n</style>\n"]},"metadata":{},"sourceType":"module"}